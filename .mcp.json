{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@executeautomation/playwright-mcp-server"]
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "self-hosted",
        "FIRECRAWL_API_URL": "http://localhost:3002"
      }
    },
    "browser-use": {
      "command": "uvx",
      "args": ["browser-use", "--mcp"],
      "env": {
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}"
      }
    },
    "blender": {
      "command": "uvx",
      "args": ["blender-mcp"]
    },
    "lunar-docs": {
      "type": "http",
      "url": "https://docs.lunarphp.com/mcp"
    },
    "huggingface": {
      "command": "npx",
      "args": ["-y", "@huggingface/mcp-client"],
      "env": {
        "HF_TOKEN": "INSERIR_TOKEN_AQUI"
      }
    }
  }
}
